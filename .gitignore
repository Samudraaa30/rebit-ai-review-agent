```gitignore
# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Dependencies
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.env/
.venv.bak/
pip-log.txt
pip-selfcheck.json

# Build artifacts
build/
dist/
*.egg
*.egg-info/
*.so
*.dylib
*.dll
*.exe
*.o
*.obj
*.out

# Testing
.coverage
coverage/
htmlcov/
.nyc_output/
.mypy_cache/
.pytest_cache/
.hypothesis/

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
```